# =============================================================================
# Aktivar Production Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# -----------------------------------------------------------------------------
# Django Core
# -----------------------------------------------------------------------------
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-random-secret-key

# Set to False in production
DEBUG=False

# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Django settings module
DJANGO_SETTINGS_MODULE=aktivar.settings_prod

# -----------------------------------------------------------------------------
# Database (PostgreSQL + PostGIS)
# -----------------------------------------------------------------------------
POSTGRES_DB=aktivar
POSTGRES_USER=aktivar
POSTGRES_PASSWORD=change-me-strong-password

# Full database URL (used by Django; overridden in docker-compose for service linking)
DATABASE_URL=postgis://aktivar:change-me-strong-password@db:5432/aktivar

# Expose DB port on host (optional, for external tools)
# DB_PORT=5432

# -----------------------------------------------------------------------------
# Redis (Cache, Celery Broker, Channels Layer)
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# Expose Redis port on host (optional)
# REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Cloudinary (Media Storage)
# -----------------------------------------------------------------------------
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# -----------------------------------------------------------------------------
# Stripe (Payments)
# -----------------------------------------------------------------------------
STRIPE_PUBLISHABLE_KEY=pk_live_your-publishable-key
STRIPE_SECRET_KEY=sk_live_your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# -----------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins for the frontend
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# -----------------------------------------------------------------------------
# Email (SMTP)
# -----------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Set to True when behind HTTPS
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# -----------------------------------------------------------------------------
# Docker Compose Port Mapping (optional overrides)
# -----------------------------------------------------------------------------
# NGINX_PORT=80
# BACKEND_PORT=8000
# FRONTEND_PORT=3000
